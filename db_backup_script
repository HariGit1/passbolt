Create a backup script on the host:
mkdir -p /opt/db-backups

vi /opt/db-backups/backup.sh
#!/bin/bash

DATE=$(date +%F_%H-%M-%S)
BACKUP_DIR="/opt/db-backups"
CONTAINER_NAME="passbolt-db-CHOC"

# Take backup
docker exec $CONTAINER_NAME \
  mysqldump -u root -p'csesupportP4ssbolt' --all-databases \
  | gzip > $BACKUP_DIR/db_backup_$DATE.sql.gz

# Delete backups older than 14 days
find $BACKUP_DIR -type f -name "*.gz" -mtime +14 -delete

Make it executable:

chmod +x /opt/db-backups/backup.sh
👉 Add cron job (runs daily at 2 AM)
crontab -e
0 2 * * * /opt/db-backups/backup.sh >> /opt/db-backups/backup.log 2>&1
